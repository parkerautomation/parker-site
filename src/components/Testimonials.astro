---
const testimonials = [
  {
    content: 'TODO: testimonial content',
    author: 'TODO: Name',
    position: 'TODO: Role',
    company: 'TODO: Company',
    avatar: '/images/placeholder.jpg', // TODO: add asset locally
  }
];
---
<section class="section bg-gray-50 dark:bg-gray-800/50">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="mb-6 text-gray-900 dark:text-white">What Our Customers Say</h2>
      <p class="text-gray-600 dark:text-gray-300">TODO: testimonials intro</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="card p-6 border border-gray-200 dark:border-gray-700 text-center">
          <blockquote class="mb-6 text-gray-700 dark:text-gray-300 italic">{t.content}</blockquote>
          <img src={t.avatar} alt={t.author} class="w-12 h-12 rounded-full mx-auto mb-4 object-cover" loading="lazy" />
          <p class="font-semibold text-gray-900 dark:text-white">{t.author}</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">{t.position}, {t.company}</p>
        </div>
      ))}
    </div>
  </div>
</section>
